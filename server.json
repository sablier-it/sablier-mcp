{
  "$schema": "https://registry.modelcontextprotocol.io/schemas/server.json",
  "name": "sablier",
  "display_name": "Sablier",
  "description": "Wall Street-grade portfolio analytics, stress-testing, and SEC filing intelligence for AI assistants. Factor models, Monte Carlo simulations, generative market paths, and GRAIN thematic analysis — in under 2 minutes.",
  "homepage": "https://sablier-ai.com/discover",
  "repository": "https://github.com/miradebs98/sablier-mcp",
  "license": "MIT",
  "is_official": true,
  "category": "finance",
  "tags": [
    "finance",
    "portfolio",
    "risk",
    "stress-testing",
    "factor-model",
    "SEC",
    "market-data",
    "Monte-Carlo",
    "optimization"
  ],
  "icons": [
    {
      "src": "https://sablier-ai.com/logo-mcp.svg",
      "mimeType": "image/svg+xml"
    }
  ],
  "privacy_policies": [
    "https://sablier-ai.com/privacy"
  ],
  "contacts": {
    "email": "team@sablier.it"
  },
  "installations": {
    "remote": {
      "type": "streamable-http",
      "url": "https://mcp.sablier-ai.com/mcp/",
      "auth": {
        "type": "oauth2"
      }
    },
    "local": {
      "type": "stdio",
      "command": "uvx",
      "args": ["sablier-mcp"],
      "env": {
        "SABLIER_API_KEY": "{SABLIER_API_KEY}"
      }
    }
  }
}
